<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JogoCacaPalavra.HomePage"
             BackgroundColor="#F0F9FF">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Grid.ColumnSpan="2" HorizontalOptions="Center" Margin="0,0,0,10">
            <Label Text="⭐ Caça-Palavras Kids ⭐" 
                   FontSize="34" 
                   FontAttributes="Bold" 
                   TextColor="#0284C7" 
                   HorizontalOptions="Center" />
            <Label Text="Encontra as palavras na grelha. Pronto para começar?" 
                   FontSize="14" 
                   TextColor="#0369A1" 
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Espaço informativo no lugar da pré-visualização -->
        <Border Grid.Row="1" Grid.Column="0" BackgroundColor="White" Padding="20" Stroke="#BAE6FD" StrokeThickness="2">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                <Label Text="Preparado para um novo desafio?" FontSize="20" FontAttributes="Bold" TextColor="#0369A1" HorizontalOptions="Center" />
                <Label Text="Pressiona 'Jogar' para abrir a grelha e começar a procurar palavras." FontSize="14" TextColor="#475569" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Border>

        <!-- Right panel with sample words and start button -->
        <VerticalStackLayout Grid.Row="1" Grid.Column="1" Margin="16,0,0,0" Spacing="12">
            <Border BackgroundColor="White" Padding="12" Stroke="#BAE6FD" StrokeThickness="2">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <VerticalStackLayout>
                    <Label Text="Palavras a encontrar" FontSize="18" FontAttributes="Bold" TextColor="#0369A1" />
                    <Label Text="GATO" FontSize="16" TextColor="#1E293B" />
                    <Label Text="PATO" FontSize="16" TextColor="#1E293B" />
                    <Label Text="LEÃO" FontSize="16" TextColor="#1E293B" />
                    <Label Text="RAPOSA" FontSize="16" TextColor="#1E293B" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Jogar" 
                    Padding="14" 
                    BackgroundColor="#0EA5E9" 
                    TextColor="White" 
                    FontAttributes="Bold" 
                    FontSize="20" 
                    CornerRadius="12"
                    Clicked="OnStartClicked" />
        </VerticalStackLayout>

        <!-- Footer -->
        <Label Grid.Row="2" Grid.ColumnSpan="2" Text="Dica: clica nas letras para selecionar palavras na grelha!" 
               HorizontalOptions="Center" TextColor="#475569" FontSize="13" Margin="0,12,0,0" />

    </Grid>
</ContentPage>
