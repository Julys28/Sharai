<Window x:Class="CacaPalavrasKids.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Caça-Palavras Kids" Height="650" Width="850"
        Background="#F0F9FF">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <!-- Título e Cabeçalho -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="⭐ Caça-Palavras Kids ⭐" FontSize="36" FontWeight="Black" Foreground="#0284C7"/>
            <TextBlock Text="Encontra as palavras escondidas na grelha!" FontSize="16" Foreground="#0369A1" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Grelha do Jogo -->
        <Border Grid.Row="1" Grid.Column="0" Background="White" CornerRadius="15" Padding="10" BorderBrush="#BAE6FD" BorderThickness="4">
            <ItemsControl x:Name="WordGridContainer">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid x:Name="MainGrid" Rows="10" Columns="10"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <!-- As células serão inseridas via C# -->
            </ItemsControl>
        </Border>

        <!-- Painel Lateral -->
        <StackPanel Grid.Row="1" Grid.Column="1" Margin="20,0,0,0">
            <Border Background="White" CornerRadius="15" Padding="15" BorderBrush="#BAE6FD" BorderThickness="4">
                <StackPanel>
                    <TextBlock Text="Palavras:" FontSize="20" FontWeight="Bold" Foreground="#0369A1" Margin="0,0,0,10"/>
                    <ItemsControl x:Name="WordsListContainer">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding WordText}" FontSize="18" Margin="0,5" 
                                           TextDecorations="{Binding Decoration}" 
                                           Foreground="{Binding Color}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Button Content="Novo Jogo" Margin="0,20,0,0" Padding="10" 
                    Background="#0EA5E9" Foreground="White" FontWeight="Bold" FontSize="18"
                    Click="OnNewGameClick">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <!-- Overlay de Vitória -->
        <Grid x:Name="WinOverlay" Grid.RowSpan="2" Grid.ColumnSpan="2" Background="#AA000000" Visibility="Collapsed">
            <Border Background="White" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="40" CornerRadius="25" BorderBrush="#FACC15" BorderThickness="8">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🏆" FontSize="72" HorizontalAlignment="Center"/>
                    <TextBlock Text="PARABÉNS!" FontSize="48" FontWeight="Black" Foreground="#EAB308"/>
                    <TextBlock Text="Encontraste tudo!" FontSize="20" Margin="0,10,0,20" HorizontalAlignment="Center"/>
                    <Button Content="Jogar Novamente" Padding="20,10" Click="OnNewGameClick" FontSize="18" FontWeight="Bold" Background="#22C55E" Foreground="White"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>